# Local dev: SQLite file
DATABASE_URL="file:./prisma/dev.db"

# Production (Turso/libSQL) — when set, client uses libSQL adapter
# LIBSQL_URL="libsql://your-db.turso.io"
# LIBSQL_AUTH_TOKEN="..."

# NIH RxNav integration (brand / generic name resolution fallback)
# No API key needed. Set MEDISCAN_USE_RXNAV=false to disable if rate-limited.
RXNAV_BASE_URL="https://rxnav.nlm.nih.gov/REST"
MEDISCAN_USE_RXNAV="true"
